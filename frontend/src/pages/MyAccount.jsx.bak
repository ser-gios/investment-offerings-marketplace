import { useEffect, useState } from 'react';
import { useNavigate } from 'react-router-dom';
import api from '../api';
import { useLang } from '../context/LangContext';
import { DollarSign, History, TrendingUp, Copy, Check, CreditCard, Zap, BarChart3, Lock, ArrowUp, ArrowDown } from 'lucide-react';

export default function MyAccount() {
  const { t } = useLang();
  const navigate = useNavigate();
  const [balance, setBalance] = useState(0);
  const [deposits, setDeposits] = useState([]);
  const [investments, setInvestments] = useState([]);
  const [loading, setLoading] = useState(true);
  const [showDepositModal, setShowDepositModal] = useState(false);
  const [depositAmount, setDepositAmount] = useState('');
  const [selectedDeposit, setSelectedDeposit] = useState(null);
  const [txHash, setTxHash] = useState('');
  const [verifying, setVerifying] = useState(false);
  const [copiedAddress, setCopiedAddress] = useState(false);
  const [activeTab, setActiveTab] = useState('balance'); // balance | deposits | investments

  const BLOCKCHAIN_ADDRESS = '0xB9705cEB7821D96bF5083f70E20E268e19c1a156';
  const MIN_DEPOSIT = 200;

  useEffect(() => {
    loadAccountData();
  }, []);

  const loadAccountData = async () => {
    try {
      setLoading(true);
      const [balRes, depRes, invRes] = await Promise.all([
        api.get('/deposits/balance/current'),
        api.get('/deposits'),
        api.get('/investments/portfolio')
      ]);

      setBalance(balRes.data.balance || 0);
      setDeposits(depRes.data || []);
      setInvestments(invRes.data.investments || []);
    } catch (err) {
      console.error('Error cargando datos:', err);
      if (err.response?.status === 401) navigate('/auth');
    } finally {
      setLoading(false);
    }
  };

  const handleCreateDeposit = async (e) => {
    e.preventDefault();
    if (!depositAmount || depositAmount < MIN_DEPOSIT) {
      alert(`Mínimo $${MIN_DEPOSIT} USDT`);
      return;
    }

    try {
      const res = await api.post('/deposits', { amount: parseFloat(depositAmount) });
      setSelectedDeposit(res.data);
      setDepositAmount('');
      // Recargar depósitos
      const depRes = await api.get('/deposits');
      setDeposits(depRes.data || []);
    } catch (err) {
      alert(err.response?.data?.error || 'Error creando depósito');
    }
  };

  const handleVerifyTransaction = async (e) => {
    e.preventDefault();
    if (!txHash || !selectedDeposit) return;

    try {
      setVerifying(true);
      const res = await api.post(`/deposits/${selectedDeposit.id}/verify`, { tx_hash: txHash });
      alert('Depósito confirmado! Tu saldo fue actualizado.');
      setTxHash('');
      setSelectedDeposit(null);
      await loadAccountData();
    } catch (err) {
      alert(err.response?.data?.error || 'Error verificando transacción');
    } finally {
      setVerifying(false);
    }
  };

  const copyToClipboard = (text) => {
    navigator.clipboard.writeText(text);
    setCopiedAddress(true);
    setTimeout(() => setCopiedAddress(false), 2000);
  };

  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-current mx-auto mb-4"></div>
          <p>Cargando...</p>
        </div>
      </div>
    );
  }

  return (
    <div style={{ background: 'linear-gradient(135deg, rgb(27, 28, 32) 0%, rgb(42, 43, 51) 100%)', minHeight: '100vh', paddingTop: '40px', paddingBottom: '60px' }}>
      <div className="page-container">
        <div className="max-w-6xl mx-auto">
          {/* Header */}
          <div style={{ marginBottom: '50px' }}>
            <h1 style={{ fontSize: '42px', fontWeight: 900, color: 'white', marginBottom: '8px' }}>
              Mi Dinero
            </h1>
            <p style={{ fontSize: '16px', color: 'var(--gray)', fontWeight: 500 }}>
              Gestiona tus depósitos e inversiones en un solo lugar
            </p>
          </div>

          {/* Balance Overview - Premium Card */}
          <div style={{
            background: 'linear-gradient(135deg, rgb(255, 214, 0) 0%, rgb(255, 140, 0) 100%)',
            borderRadius: '20px',
            padding: '40px',
            color: 'white',
            marginBottom: '40px',
            boxShadow: '0 20px 60px rgba(255, 214, 0, 0.3)',
            position: 'relative',
            overflow: 'hidden'
          }}>
            <div style={{ position: 'absolute', top: -50, right: -50, width: 200, height: 200, background: 'rgba(255,255,255,0.1)', borderRadius: '50%' }}></div>
            <div style={{ position: 'relative', zIndex: 1 }}>
              <p style={{ fontSize: '14px', opacity: 0.95, fontWeight: 600, textTransform: 'uppercase', letterSpacing: '1px', marginBottom: '12px' }}>
                Balance Disponible
              </p>
              <h2 style={{ fontSize: '52px', fontWeight: 900, marginBottom: '16px' }}>
                ${balance.toFixed(2)}
              </h2>
              <p style={{ fontSize: '13px', opacity: 0.9 }}>USDT en BNB Chain</p>
              <div style={{ marginTop: '20px', paddingTop: '20px', borderTop: '1px solid rgba(255,255,255,0.3)', display: 'flex', gap: '30px' }}>
                <div>
                  <p style={{ fontSize: '12px', opacity: 0.8 }}>Depósitos totales</p>
                  <p style={{ fontSize: '20px', fontWeight: 'bold', marginTop: '4px' }}>
                    ${deposits.reduce((s, d) => s + (d.status === 'confirmed' ? d.amount : 0), 0).toFixed(2)}
                  </p>
                </div>
                <div>
                  <p style={{ fontSize: '12px', opacity: 0.8 }}>Invertido</p>
                  <p style={{ fontSize: '20px', fontWeight: 'bold', marginTop: '4px' }}>
                    ${investments.reduce((s, i) => s + (i.status === 'active' ? i.amount : 0), 0).toFixed(2)}
                  </p>
                </div>
              </div>
            </div>
          </div>

          {/* Stats Cards */}
          <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div style={{
              background: 'rgba(15, 165, 233, 0.1)',
              borderRadius: '16px',
              padding: '20px',
              border: '1px solid rgba(15, 165, 233, 0.3)',
              backdropFilter: 'blur(10px)'
            }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start' }}>
                <div>
                  <p style={{ fontSize: '12px', color: 'var(--gray)', textTransform: 'uppercase', fontWeight: 600 }}>Depósitos</p>
                  <h3 style={{ fontSize: '32px', fontWeight: 'bold', marginTop: '12px', color: 'rgb(15, 165, 233)' }}>
                    {deposits.length}
                  </h3>
                  <p style={{ fontSize: '11px', color: 'var(--gray)', marginTop: '8px' }}>
                    {deposits.filter(d => d.status === 'confirmed').length} confirmados
                  </p>
                </div>
                <div style={{ width: 50, height: 50, background: 'rgba(15, 165, 233, 0.2)', borderRadius: '12px', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                  <CreditCard size={28} color="rgb(15, 165, 233)" />
                </div>
              </div>
            </div>

            <div style={{
              background: 'rgba(34, 197, 94, 0.1)',
              borderRadius: '16px',
              padding: '20px',
              border: '1px solid rgba(34, 197, 94, 0.3)',
              backdropFilter: 'blur(10px)'
            }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start' }}>
                <div>
                  <p style={{ fontSize: '12px', color: 'var(--gray)', textTransform: 'uppercase', fontWeight: 600 }}>Inversiones</p>
                  <h3 style={{ fontSize: '32px', fontWeight: 'bold', marginTop: '12px', color: 'rgb(34, 197, 94)' }}>
                    {investments.filter(i => i.status === 'active').length}
                  </h3>
                  <p style={{ fontSize: '11px', color: 'var(--gray)', marginTop: '8px' }}>activas</p>
                </div>
                <div style={{ width: 50, height: 50, background: 'rgba(34, 197, 94, 0.2)', borderRadius: '12px', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                  <TrendingUp size={28} color="rgb(34, 197, 94)" />
                </div>
              </div>
            </div>

            <div style={{
              background: 'rgba(168, 85, 247, 0.1)',
              borderRadius: '16px',
              padding: '20px',
              border: '1px solid rgba(168, 85, 247, 0.3)',
              backdropFilter: 'blur(10px)'
            }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start' }}>
                <div>
                  <p style={{ fontSize: '12px', color: 'var(--gray)', textTransform: 'uppercase', fontWeight: 600 }}>Ganancia</p>
                  <h3 style={{ fontSize: '32px', fontWeight: 'bold', marginTop: '12px', color: 'rgb(168, 85, 247)' }}>
                    ${investments.reduce((s, i) => s + (i.status === 'active' ? (i.interest_earned || 0) : 0), 0).toFixed(2)}
                  </h3>
                  <p style={{ fontSize: '11px', color: 'var(--gray)', marginTop: '8px' }}>intereses ganados</p>
                </div>
                <div style={{ width: 50, height: 50, background: 'rgba(168, 85, 247, 0.2)', borderRadius: '12px', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
                  <Zap size={28} color="rgb(168, 85, 247)" />
                </div>
              </div>
            </div>
          </div>

        {/* Tabs - Premium Design */}
        <div style={{ marginBottom: '40px' }}>
          <div style={{
            display: 'flex',
            gap: '12px',
            background: 'rgba(255, 214, 0, 0.05)',
            borderRadius: '16px',
            padding: '8px',
            border: '1px solid rgba(255, 214, 0, 0.2)',
            backdropFilter: 'blur(10px)'
          }}>
            {[
              { id: 'balance', label: 'Depositar', icon: DollarSign },
              { id: 'deposits', label: 'Historial', icon: History },
              { id: 'investments', label: 'Inversiones', icon: TrendingUp }
            ].map(tab => (
              <button
                key={tab.id}
                onClick={() => setActiveTab(tab.id)}
                style={{
                  flex: 1,
                  padding: '12px 16px',
                  fontSize: '14px',
                  fontWeight: activeTab === tab.id ? '700' : '500',
                  borderRadius: '12px',
                  color: activeTab === tab.id ? 'rgb(5, 7, 15)' : 'var(--gray)',
                  background: activeTab === tab.id ? 'linear-gradient(135deg, rgb(255, 214, 0) 0%, rgb(255, 140, 0) 100%)' : 'transparent',
                  border: 'none',
                  cursor: 'pointer',
                  transition: 'all 0.3s ease',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  gap: '8px',
                  boxShadow: activeTab === tab.id ? '0 8px 24px rgba(255, 214, 0, 0.25)' : 'none'
                }}
              >
                <tab.icon size={18} />
                {tab.label}
              </button>
            ))}
          </div>
        </div>

        {/* Tab Content */}
        {activeTab === 'balance' && (
          <div>
            {!selectedDeposit ? (
              // Formulario de depósito - Premium Design
              <div style={{
                background: 'linear-gradient(135deg, rgba(255, 214, 0, 0.05) 0%, rgba(255, 140, 0, 0.02) 100%)',
                borderRadius: '20px',
                padding: '40px',
                border: '1px solid rgba(255, 214, 0, 0.2)',
                backdropFilter: 'blur(10px)'
              }}>
                <div style={{ marginBottom: '32px' }}>
                  <h3 style={{ fontSize: '26px', fontWeight: 900, marginBottom: '8px', color: 'white' }}>
                    Depositar Fondos
                  </h3>
                  <p style={{ fontSize: '14px', color: 'var(--gray)' }}>
                    Agrega USDT a tu cuenta de forma segura y rápida
                  </p>
                </div>

                <form onSubmit={handleCreateDeposit}>
                  <div style={{ marginBottom: '24px' }}>
                    <label style={{ display: 'block', fontSize: '13px', fontWeight: 600, marginBottom: '10px', textTransform: 'uppercase', letterSpacing: '0.5px', color: 'var(--gray)' }}>
                      Cantidad USDT
                    </label>
                    <div style={{ position: 'relative' }}>
                      <input
                        type="number"
                        min={MIN_DEPOSIT}
                        step="0.01"
                        value={depositAmount}
                        onChange={(e) => setDepositAmount(e.target.value)}
                        placeholder={`Mínimo $${MIN_DEPOSIT}`}
                        className="input-field"
                        style={{
                          fontSize: '16px',
                          padding: '14px 16px',
                          background: 'rgba(255, 255, 255, 0.08)',
                          border: '1px solid rgba(255, 214, 0, 0.3)',
                          borderRadius: '12px',
                          color: 'white'
                        }}
                        required
                      />
                      <span style={{ position: 'absolute', right: '16px', top: '50%', transform: 'translateY(-50%)', color: 'var(--gray)', fontSize: '14px' }}>USDT</span>
                    </div>
                    <p style={{ fontSize: '12px', color: 'var(--gray)', marginTop: '10px' }}>
                      Mínimo de depósito: ${MIN_DEPOSIT} USDT en BNB Chain
                    </p>
                  </div>

                  <button
                    type="submit"
                    style={{
                      width: '100%',
                      padding: '14px',
                      background: 'linear-gradient(135deg, rgb(255, 214, 0) 0%, rgb(255, 140, 0) 100%)',
                      color: 'rgb(5, 7, 15)',
                      border: 'none',
                      borderRadius: '12px',
                      fontSize: '15px',
                      fontWeight: 700,
                      cursor: 'pointer',
                      transition: 'all 0.3s ease',
                      boxShadow: '0 8px 24px rgba(255, 214, 0, 0.3)'
                    }}
                    onMouseOver={(e) => {
                      e.target.style.transform = 'translateY(-2px)';
                      e.target.style.boxShadow = '0 12px 32px rgba(255, 214, 0, 0.4)';
                    }}
                    onMouseOut={(e) => {
                      e.target.style.transform = 'translateY(0)';
                      e.target.style.boxShadow = '0 8px 24px rgba(255, 214, 0, 0.3)';
                    }}
                  >
                    Continuar con Depósito
                  </button>
                </form>

                <div style={{
                  background: 'rgba(59, 130, 246, 0.1)',
                  borderRadius: '12px',
                  padding: '20px',
                  marginTop: '28px',
                  border: '1px solid rgba(59, 130, 246, 0.3)',
                  backdropFilter: 'blur(10px)'
                }}>
                  <div style={{ display: 'flex', gap: '12px', marginBottom: '12px' }}>
                    <Lock size={18} color="rgb(59, 130, 246)" style={{ flexShrink: 0, marginTop: '2px' }} />
                    <div>
                      <p style={{ fontSize: '13px', fontWeight: 600, color: 'rgb(59, 130, 246)', marginBottom: '8px' }}>
                        Cómo funciona
                      </p>
                      <p style={{ fontSize: '12px', lineHeight: '1.8', color: 'var(--gray)' }}>
                        1. Ingresa la cantidad que deseas depositar<br/>
                        2. Envía USDT a la dirección en red BNB Chain<br/>
                        3. Proporciona el hash de tu transacción<br/>
                        4. Tu saldo se acredita automáticamente ✓
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              // Verificación de transacción
              <div style={{
                background: 'var(--card)',
                borderRadius: '12px',
                padding: '24px',
                border: '1px solid var(--border)'
              }}>
                <h3 style={{ fontSize: '18px', fontWeight: 'bold', marginBottom: '20px' }}>
                  Verificar Transacción
                </h3>

                <div style={{
                  background: 'rgba(34, 197, 94, 0.1)',
                  borderRadius: '8px',
                  padding: '16px',
                  marginBottom: '20px',
                  border: '1px solid rgb(34, 197, 94)'
                }}>
                  <p style={{ fontSize: '14px', marginBottom: '8px' }}>Cantidad a depositar:</p>
                  <p style={{ fontSize: '24px', fontWeight: 'bold', color: 'rgb(34, 197, 94)' }}>
                    ${selectedDeposit.amount} USDT
                  </p>
                </div>

                <div style={{ marginBottom: '20px' }}>
                  <p style={{ fontSize: '14px', fontWeight: 'bold', marginBottom: '8px' }}>
                    Dirección de Billetera (BNB Chain)
                  </p>
                  <div style={{
                    background: 'var(--bg)',
                    border: '1px solid var(--border)',
                    borderRadius: '8px',
                    padding: '12px',
                    display: 'flex',
                    alignItems: 'center',
                    justifyContent: 'space-between'
                  }}>
                    <code style={{ fontSize: '12px', wordBreak: 'break-all' }}>
                      {BLOCKCHAIN_ADDRESS}
                    </code>
                    <button
                      type="button"
                      onClick={() => copyToClipboard(BLOCKCHAIN_ADDRESS)}
                      style={{
                        background: 'none',
                        border: 'none',
                        cursor: 'pointer',
                        marginLeft: '12px',
                        flexShrink: 0
                      }}
                    >
                      {copiedAddress ? (
                        <Check size={18} color="var(--emerald)" />
                      ) : (
                        <Copy size={18} color="var(--gray)" />
                      )}
                    </button>
                  </div>
                  <p style={{ fontSize: '12px', color: 'var(--gray)', marginTop: '8px' }}>
                    ⚠️ Asegúrate de enviar USDT en la red BNB Chain únicamente
                  </p>
                </div>

                <form onSubmit={handleVerifyTransaction}>
                  <div style={{ marginBottom: '20px' }}>
                    <label style={{ display: 'block', fontSize: '14px', marginBottom: '8px' }}>
                      Hash de Transacción
                    </label>
                    <input
                      type="text"
                      value={txHash}
                      onChange={(e) => setTxHash(e.target.value)}
                      placeholder="0x..."
                      className="input-field"
                      required
                    />
                    <p style={{ fontSize: '12px', color: 'var(--gray)', marginTop: '8px' }}>
                      Copia el hash (TX Hash) de tu transacción desde el explorador de bloques
                    </p>
                  </div>

                  <div style={{ display: 'flex', gap: '12px' }}>
                    <button
                      type="submit"
                      className="btn btn-primary"
                      disabled={verifying}
                      style={{ flex: 1 }}
                    >
                      {verifying ? 'Verificando...' : 'Verificar Transacción'}
                    </button>
                    <button
                      type="button"
                      onClick={() => {
                        setSelectedDeposit(null);
                        setTxHash('');
                      }}
                      className="btn"
                      style={{ flex: 1 }}
                    >
                      Cancelar
                    </button>
                  </div>
                </form>
              </div>
            )}
          </div>
        )}

        {activeTab === 'deposits' && (
          <div>
            {deposits.length === 0 ? (
              <div style={{
                textAlign: 'center',
                padding: '60px 20px',
                background: 'rgba(255, 214, 0, 0.05)',
                borderRadius: '16px',
                border: '1px dashed rgba(255, 214, 0, 0.2)'
              }}>
                <DollarSign size={48} color="var(--gray)" style={{ margin: '0 auto 16px', opacity: 0.5 }} />
                <p style={{ fontSize: '16px', color: 'var(--gray)', fontWeight: 500 }}>
                  No hay depósitos registrados
                </p>
                <p style={{ fontSize: '13px', color: 'var(--gray)', marginTop: '8px', opacity: 0.7 }}>
                  Crea tu primer depósito para comenzar a invertir
                </p>
              </div>
            ) : (
              <div style={{ display: 'grid', gap: '12px' }}>
                {deposits.map(dep => (
                  <div key={dep.id} style={{
                    background: 'rgba(255, 214, 0, 0.03)',
                    borderRadius: '16px',
                    padding: '16px',
                    border: '1px solid rgba(255, 214, 0, 0.15)',
                    backdropFilter: 'blur(10px)',
                    display: 'grid',
                    gridTemplateColumns: '1fr auto',
                    alignItems: 'center',
                    gap: '16px',
                    transition: 'all 0.3s ease',
                    cursor: 'pointer'
                  }}
                  onMouseOver={(e) => {
                    e.currentTarget.style.background = 'rgba(255, 214, 0, 0.08)';
                    e.currentTarget.style.borderColor = 'rgba(255, 214, 0, 0.3)';
                  }}
                  onMouseOut={(e) => {
                    e.currentTarget.style.background = 'rgba(255, 214, 0, 0.03)';
                    e.currentTarget.style.borderColor = 'rgba(255, 214, 0, 0.15)';
                  }}
                  >
                    <div style={{ display: 'flex', gap: '12px', alignItems: 'center' }}>
                      <div style={{
                        width: 40,
                        height: 40,
                        borderRadius: '10px',
                        background: dep.status === 'confirmed' ? 'rgba(34, 197, 94, 0.2)' : 'rgba(239, 68, 68, 0.2)',
                        display: 'flex',
                        alignItems: 'center',
                        justifyContent: 'center'
                      }}>
                        {dep.status === 'confirmed' ? (
                          <Check size={20} color="rgb(34, 197, 94)" />
                        ) : (
                          <CreditCard size={20} color="rgb(239, 68, 68)" />
                        )}
                      </div>
                      <div>
                        <p style={{ fontSize: '14px', fontWeight: 600, color: 'white' }}>
                          ${dep.amount.toFixed(2)} USDT
                        </p>
                        <p style={{ fontSize: '12px', color: 'var(--gray)', marginTop: '4px' }}>
                          {new Date(dep.created_at).toLocaleDateString('es-ES', { weekday: 'short', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}
                        </p>
                      </div>
                    </div>
                    <div style={{ textAlign: 'right' }}>
                      <span style={{
                        display: 'inline-block',
                        padding: '6px 14px',
                        borderRadius: '20px',
                        fontSize: '12px',
                        fontWeight: 700,
                        background: dep.status === 'confirmed' ? 'rgba(34, 197, 94, 0.2)' : 'rgba(239, 68, 68, 0.2)',
                        color: dep.status === 'confirmed' ? 'rgb(34, 197, 94)' : 'rgb(239, 68, 68)',
                        textTransform: 'uppercase',
                        letterSpacing: '0.5px'
                      }}>
                        {dep.status === 'confirmed' ? '✓ Confirmado' : '⏳ Pendiente'}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {activeTab === 'investments' && (
          <div>
            {investments.length === 0 ? (
              <div style={{
                textAlign: 'center',
                padding: '60px 20px',
                background: 'rgba(255, 214, 0, 0.05)',
                borderRadius: '16px',
                border: '1px dashed rgba(255, 214, 0, 0.2)'
              }}>
                <TrendingUp size={48} color="var(--gray)" style={{ margin: '0 auto 16px', opacity: 0.5 }} />
                <p style={{ fontSize: '16px', color: 'var(--gray)', fontWeight: 500 }}>
                  No hay inversiones registradas
                </p>
                <p style={{ fontSize: '13px', color: 'var(--gray)', marginTop: '8px', opacity: 0.7 }}>
                  Invierte en proyectos para comenzar a generar ganancias
                </p>
              </div>
            ) : (
              <div className="grid gap-4">
                {investments.map(inv => {
                  const gainPercentage = inv.amount > 0 ? ((inv.current_value - inv.amount) / inv.amount * 100).toFixed(1) : 0;
                  const isGaining = inv.current_value >= inv.amount;
                  
                  return (
                    <div
                      key={inv.id}
                      style={{
                        background: 'linear-gradient(135deg, rgba(34, 197, 94, 0.05) 0%, rgba(34, 197, 94, 0.02) 100%)',
                        border: '1px solid rgba(34, 197, 94, 0.2)',
                        borderRadius: '16px',
                        padding: '20px',
                        transition: 'all 0.3s ease',
                        backdropFilter: 'blur(10px)'
                      }}
                      onMouseOver={(e) => {
                        e.currentTarget.style.borderColor = 'rgba(34, 197, 94, 0.4)';
                        e.currentTarget.style.background = 'linear-gradient(135deg, rgba(34, 197, 94, 0.08) 0%, rgba(34, 197, 94, 0.03) 100%)';
                      }}
                      onMouseOut={(e) => {
                        e.currentTarget.style.borderColor = 'rgba(34, 197, 94, 0.2)';
                        e.currentTarget.style.background = 'linear-gradient(135deg, rgba(34, 197, 94, 0.05) 0%, rgba(34, 197, 94, 0.02) 100%)';
                      }}
                    >
                      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start', marginBottom: '16px' }}>
                        <div>
                          <h4 style={{ fontSize: '18px', fontWeight: 'bold', color: 'white' }}>
                            {inv.project_name}
                          </h4>
                          <p style={{ fontSize: '13px', color: 'var(--gray)', marginTop: '6px' }}>
                            Invertido: ${inv.amount.toFixed(2)} USDT
                          </p>
                        </div>
                        <div style={{ textAlign: 'right' }}>
                          <span style={{
                            display: 'inline-block',
                            padding: '6px 14px',
                            borderRadius: '20px',
                            fontSize: '12px',
                            fontWeight: 700,
                            background: inv.status === 'active' ? 'rgba(34, 197, 94, 0.2)' : 'rgba(107, 114, 128, 0.2)',
                            color: inv.status === 'active' ? 'rgb(34, 197, 94)' : 'rgb(107, 114, 128)',
                            textTransform: 'uppercase',
                            letterSpacing: '0.5px'
                          }}>
                            {inv.status === 'active' ? '✓ Activa' : inv.status}
                          </span>
                          <p style={{
                            fontSize: '13px',
                            fontWeight: '700',
                            marginTop: '10px',
                            color: isGaining ? 'rgb(34, 197, 94)' : 'rgb(239, 68, 68)',
                            display: 'flex',
                            alignItems: 'center',
                            justifyContent: 'flex-end',
                            gap: '4px'
                          }}>
                            {isGaining ? <ArrowUp size={16} /> : <ArrowDown size={16} />}
                            {gainPercentage}%
                          </p>
                        </div>
                      </div>

                      <div style={{
                        display: 'grid',
                        gridTemplateColumns: 'repeat(auto-fit, minmax(160px, 1fr))',
                        gap: '16px'
                      }}>
                        <div style={{
                          background: 'rgba(255, 255, 255, 0.05)',
                          borderRadius: '12px',
                          padding: '12px',
                          border: '1px solid rgba(255, 255, 255, 0.1)'
                        }}>
                          <p style={{ fontSize: '11px', color: 'var(--gray)', textTransform: 'uppercase', fontWeight: 600, letterSpacing: '0.5px' }}>Valor Actual</p>
                          <p style={{ fontWeight: '900', fontSize: '18px', marginTop: '8px', color: 'white' }}>
                            ${inv.current_value?.toFixed(2) || '0.00'}
                          </p>
                        </div>
                        <div style={{
                          background: 'rgba(34, 197, 94, 0.1)',
                          borderRadius: '12px',
                          padding: '12px',
                          border: '1px solid rgba(34, 197, 94, 0.3)'
                        }}>
                          <p style={{ fontSize: '11px', color: 'rgb(34, 197, 94)', textTransform: 'uppercase', fontWeight: 600, letterSpacing: '0.5px' }}>Ganancia</p>
                          <p style={{ fontWeight: '900', fontSize: '18px', marginTop: '8px', color: 'rgb(34, 197, 94)' }}>
                            +${inv.interest_earned?.toFixed(2) || '0.00'}
                          </p>
                        </div>
                        <div style={{
                          background: 'rgba(255, 255, 255, 0.05)',
                          borderRadius: '12px',
                          padding: '12px',
                          border: '1px solid rgba(255, 255, 255, 0.1)'
                        }}>
                          <p style={{ fontSize: '11px', color: 'var(--gray)', textTransform: 'uppercase', fontWeight: 600, letterSpacing: '0.5px' }}>Frecuencia</p>
                          <p style={{ fontWeight: '700', marginTop: '8px', fontSize: '15px', color: 'white' }}>
                            {inv.payout_frequency === 'monthly' ? 'Mensual' : inv.payout_frequency === 'quarterly' ? 'Trimestral' : 'Anual'}
                          </p>
                        </div>
                        <div style={{
                          background: 'rgba(255, 214, 0, 0.1)',
                          borderRadius: '12px',
                          padding: '12px',
                          border: '1px solid rgba(255, 214, 0, 0.3)'
                        }}>
                          <p style={{ fontSize: '11px', color: 'rgba(255, 214, 0, 0.8)', textTransform: 'uppercase', fontWeight: 600, letterSpacing: '0.5px' }}>Tasa Anual</p>
                          <p style={{ fontWeight: '900', marginTop: '8px', fontSize: '18px', color: 'rgb(255, 214, 0)' }}>
                            {inv.interest_rate}%
                          </p>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
